# =========================================================================
# Chidakara Backend Configuration Example
# Copy this file to .env and configure the secrets for production/staging.
# =========================================================================

# Gemini API Key for autonomous planners and reflection agents (Required)
GOOGLE_API_KEY=your_gemini_api_key_here

# Path to ChromaDB persistent collection directory (Optional, defaults to local chroma_db/)
# For production environments, mount a persistent volume or set database paths.
CHROMA_DB_PATH=chroma_db/

# Web Search Provider for Web Intelligence Agent (Optional, defaults to duckduckgo)
# Supports: duckduckgo
WEB_PROVIDER=duckduckgo

# Server Bind Address and Port for FastAPI
HOST=0.0.0.0
PORT=8000
